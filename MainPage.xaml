<Page
    x:Class="kalk.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:kalk"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Width="600" Height="1002">

    <Page.Resources>
        <DataTemplate x:Key="WalutyItemTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding kod_waluty}" Width="55"/>
                <TextBlock Text=": "/>
                <TextBlock Text="{Binding kurs_sredni}" Width="55"/>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="White" Loaded="Grid_Loaded">
        <TextBox x:Name="txtKwota" InputScope="CurrencyAmount" HorizontalAlignment="Left" Margin="242,203,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="45" Width="279" FontSize="24" TextChanged="txtKwota_TextChanged" BorderThickness="2" BorderBrush="#661A6696" FocusVisualPrimaryBrush="#FF000835" TextAlignment="Right"/>
        <TextBlock x:Name="tbPrzeliczona" HorizontalAlignment="Left" Margin="242,300,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="49" Width="279" Foreground="Black" FontSize="24" TextAlignment="Right"/>
        <ListBox x:Name="IbxZWaluty" ItemTemplate="{StaticResource WalutyItemTemplate}" Margin="39,486,339,186" SelectionChanged="IbxZWaluty_SelectionChanged" Width="220" Height="330" Background="LightGray" BorderThickness="1"/>
        <ListBox x:Name="IbxNaWalute" ItemTemplate="{StaticResource WalutyItemTemplate}" Margin="342,486,38,186" Width="220" Height="330" SelectionChanged="IbxNaWalute_SelectionChanged" Background="LightGray" BorderThickness="1"/>
        <TextBlock HorizontalAlignment="Left" Margin="40,48,0,0" TextWrapping="Wrap" Text="kalkulator" VerticalAlignment="Top" Height="70" Width="364" FontSize="48" Foreground="Black"/>
        <TextBlock HorizontalAlignment="Left" Margin="120,210,0,0" TextWrapping="Wrap" Text="z waluty:" VerticalAlignment="Top" Height="43" Width="103" FontSize="24" Foreground="Black"/>
        <TextBlock HorizontalAlignment="Left" Margin="103,301,0,0" TextWrapping="Wrap" Text="przeliczone:" VerticalAlignment="Top" Height="64" Width="135" Foreground="Black" FontSize="24"/>
        <TextBlock HorizontalAlignment="Left" Margin="177,421,0,0" TextWrapping="Wrap" Text="z waluty   --&gt;   na walutę" VerticalAlignment="Top" Width="324" Height="48" Foreground="Black" FontSize="24"/>
        <Button x:Name="btnOProgramie" Content="O Programie" Margin="40,864,0,0" VerticalAlignment="Top" Height="71" Width="228" Background="#33000000" FontSize="36" Click="btnOProgramie_Click" Foreground="Black"/>
        <Button x:Name="btnPomoc" Content="Pomoc" Margin="342,864,0,0" VerticalAlignment="Top" Height="71" Width="220" Click="btnPomoc_Click" Background="#33000000" FontSize="36"/>
        <TextBlock x:Name="tbDataAktualizacji" HorizontalAlignment="Left" Margin="382,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="48" Width="204" Foreground="Black"/>
        <TextBlock x:Name="ZWaluty" HorizontalAlignment="Left" Margin="534,210,0,0" TextWrapping="Wrap" Text="{Binding ElementName=IbxZWaluty, Path=SelectedItem.kod_waluty}" VerticalAlignment="Top" Height="31" FontSize="24" Width="56"/>
        <TextBlock x:Name="NaWalute" HorizontalAlignment="Left" Margin="534,301,0,0" TextWrapping="Wrap" Text="{Binding ElementName=IbxNaWalute, Path=SelectedItem.kod_waluty}" VerticalAlignment="Top" Height="31" SelectionChanged="TextBlock_SelectionChanged" FontSize="24" Width="56"/>

    </Grid>
</Page>
